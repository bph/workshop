{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "login":true,
  "plugins":["create-block-theme","wordpress-importer","gutenberg"],
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Concrete & Light",
        "blogdescription": "Heritage Architecture & Restoration, Mumbai",
        "permalink_structure": "/%postname%/",
        "timezone_string": "Asia/Kolkata",
        "start_of_week": "1",
        "default_comment_status": "closed",
        "show_on_front": "page",
        "page_on_front": "4"
      }
    },

    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/bph/workshop/main/concrete-and-light.xml"
      }
    }
  ]
}
