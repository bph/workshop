{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "base",           "color": "#FFFFFF", "name": "Base"           },
        { "slug": "primary",        "color": "#006D77", "name": "Primary"        },
        { "slug": "secondary",      "color": "#3B0764", "name": "Secondary"      },
        { "slug": "contrast",       "color": "#1E3A5F", "name": "Contrast"       },
        { "slug": "accent",         "color": "#F97316", "name": "Accent"         },
        { "slug": "accent-alt",     "color": "#F5C518", "name": "Accent Alt"     },
        { "slug": "base-dark",      "color": "#0D0D1A", "name": "Base Dark"      },
        { "slug": "primary-dark",   "color": "#3AB8C5", "name": "Primary Dark"   },
        { "slug": "secondary-dark", "color": "#C084FC", "name": "Secondary Dark" },
        { "slug": "contrast-dark",  "color": "#E2E8F0", "name": "Contrast Dark"  }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Fraunces, serif",
          "fontFace": [
            {
              "fontFamily": "Fraunces",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/fraunces/Fraunces-VariableFont.woff2"]
            },
            {
              "fontFamily": "Fraunces",
              "fontWeight": "100 900",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/fraunces/Fraunces-Italic-VariableFont.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/inter/Inter-VariableFont.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs",  "size": "0.75rem",  "name": "XS"     },
        { "slug": "sm",  "size": "0.875rem", "name": "Small"  },
        { "slug": "md",  "size": "1rem",     "name": "Medium" },
        { "slug": "lg",  "size": "1.25rem",  "name": "Large"  },
        { "slug": "xl",  "size": "1.5rem",   "name": "XL"     },
        { "slug": "2xl", "size": "2rem",     "name": "2XL"    },
        { "slug": "3xl", "size": "2.5rem",   "name": "3XL"    },
        { "slug": "4xl", "size": "3.5rem",   "name": "4XL"    }
      ],
      "lineHeight": true,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textTransform": true
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        { "slug": "xs",  "size": "0.5rem",  "name": "XS"     },
        { "slug": "sm",  "size": "1rem",    "name": "Small"  },
        { "slug": "md",  "size": "1.5rem",  "name": "Medium" },
        { "slug": "lg",  "size": "2rem",    "name": "Large"  },
        { "slug": "xl",  "size": "3rem",    "name": "XL"     },
        { "slug": "2xl", "size": "4rem",    "name": "2XL"    },
        { "slug": "3xl", "size": "6rem",    "name": "3XL"    }
      ],
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|md",
      "lineHeight": "1.7"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|md"
    },
    "elements": {
      "link": {
        "color": { "text": "var:preset|color|primary" },
        ":hover": { "color": { "text": "var:preset|color|accent" } }
      },
      "h1": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "800",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        },
        "color": { "text": "var:preset|color|secondary" }
      },
      "h2": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|3xl",
          "fontWeight": "700",
          "lineHeight": "1.2",
          "letterSpacing": "-0.01em"
        },
        "color": { "text": "var:preset|color|secondary" }
      },
      "h3": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontWeight": "600",
          "lineHeight": "1.3"
        },
        "color": { "text": "var:preset|color|contrast" }
      },
      "h4": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "color": { "text": "var:preset|color|contrast" }
      },
      "h5": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|lg",
          "fontWeight": "700",
          "letterSpacing": "0.02em",
          "textTransform": "uppercase"
        },
        "color": { "text": "var:preset|color|primary" }
      },
      "h6": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "700",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        },
        "color": { "text": "var:preset|color|primary" }
      },
      "button": {
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|base"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "600",
          "letterSpacing": "0.03em",
          "textTransform": "uppercase"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|primary",
            "text": "var:preset|color|base"
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|base"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "600",
          "letterSpacing": "0.03em"
        },
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|base" },
            ":hover": { "color": { "text": "var:preset|color|accent-alt" } }
          }
        }
      },
      "core/site-title": {
        "color": { "text": "var:preset|color|base" },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "700"
        },
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|base" },
            ":hover": { "color": { "text": "var:preset|color|accent-alt" } }
          }
        }
      },
      "core/site-tagline": {
        "color": { "text": "var:preset|color|contrast-dark" },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|sm"
        }
      },
      "core/post-title": {
        "color": { "text": "var:preset|color|secondary" },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "800",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        }
      },
      "core/cover": {
        "color": {
          "background": "var:preset|color|secondary",
          "text": "var:preset|color|base"
        }
      },
      "core/quote": {
        "color": {
          "background": "var:preset|color|base",
          "text": "var:preset|color|secondary"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontStyle": "italic",
          "fontWeight": "400",
          "lineHeight": "1.5"
        },
        "border": { "color": "var:preset|color|primary" }
      },
      "core/pullquote": {
        "color": {
          "background": "var:preset|color|secondary",
          "text": "var:preset|color|base"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontStyle": "italic",
          "fontWeight": "300",
          "lineHeight": "1.4"
        },
        "elements": {
          "link": { "color": { "text": "var:preset|color|accent-alt" } }
        }
      },
      "core/code": {
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|accent-alt"
        },
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "var:preset|font-size|sm",
          "lineHeight": "1.8"
        }
      },
      "core/separator": {
        "color": { "text": "var:preset|color|primary" }
      },
      "core/search": {
        "elements": {
          "button": {
            "color": {
              "background": "var:preset|color|primary",
              "text": "var:preset|color|base"
            }
          }
        }
      },
      "core/tag-cloud": {
        "color": { "text": "var:preset|color|primary" }
      },
      "core/latest-posts": {
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|secondary" },
            ":hover": { "color": { "text": "var:preset|color|accent" } }
          }
        }
      },
      "core/group": {
        "variations": {
          "dark-band": {
            "color": {
              "background": "var:preset|color|contrast",
              "text": "var:preset|color|base"
            },
            "elements": {
              "heading": {
                "color": { "text": "var:preset|color|base" }
              },
              "link": {
                "color": { "text": "var:preset|color|accent-alt" },
                ":hover": { "color": { "text": "var:preset|color|accent" } }
              },
              "button": {
                "color": {
                  "background": "var:preset|color|accent",
                  "text": "var:preset|color|base"
                },
                ":hover": {
                  "color": {
                    "background": "var:preset|color|accent-alt",
                    "text": "var:preset|color|contrast"
                  }
                }
              }
            }
          },
          "accent-band": {
            "color": {
              "background": "var:preset|color|secondary",
              "text": "var:preset|color|base"
            },
            "elements": {
              "heading": {
                "color": { "text": "var:preset|color|base" }
              },
              "link": {
                "color": { "text": "var:preset|color|accent-alt" },
                ":hover": { "color": { "text": "var:preset|color|primary-dark" } }
              },
              "button": {
                "color": {
                  "background": "var:preset|color|accent",
                  "text": "var:preset|color|base"
                },
                ":hover": {
                  "color": {
                    "background": "var:preset|color|base",
                    "text": "var:preset|color|secondary"
                  }
                }
              }
            }
          },
          "highlight": {
            "color": {
              "background": "var:preset|color|accent-alt",
              "text": "var:preset|color|contrast"
            },
            "elements": {
              "heading": {
                "color": { "text": "var:preset|color|secondary" }
              },
              "link": {
                "color": { "text": "var:preset|color|primary" },
                ":hover": { "color": { "text": "var:preset|color|secondary" } }
              },
              "button": {
                "color": {
                  "background": "var:preset|color|contrast",
                  "text": "var:preset|color|base"
                },
                ":hover": {
                  "color": {
                    "background": "var:preset|color|secondary",
                    "text": "var:preset|color|base"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
