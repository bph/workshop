{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Editorial Authority",
  "settings": {
    "typography": {
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Playfair Display, serif",
          "fontFace": [
            {
              "fontFamily": "Playfair Display",
              "fontWeight": "400 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/playfair-display/PlayfairDisplay-VariableFont.woff2"]
            },
            {
              "fontFamily": "Playfair Display",
              "fontWeight": "400 900",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/playfair-display/PlayfairDisplay-Italic-VariableFont.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Source Serif 4, serif",
          "fontFace": [
            {
              "fontFamily": "Source Serif 4",
              "fontWeight": "200 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/source-serif-4/SourceSerif4-VariableFont.woff2"]
            }
          ]
        },
        {
          "slug": "ui",
          "name": "UI",
          "fontFamily": "DM Sans, sans-serif",
          "fontFace": [
            {
              "fontFamily": "DM Sans",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/dm-sans/DMSans-VariableFont.woff2"]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "lineHeight": "1.8"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "900",
          "lineHeight": "1.1",
          "letterSpacing": "-0.03em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|3xl",
          "fontWeight": "700",
          "lineHeight": "1.2",
          "fontStyle": "italic"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "700",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui",
          "fontSize": "var:preset|font-size|xs",
          "fontWeight": "700",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        }
      },
      "button": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "600",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "500",
          "letterSpacing": "0.04em"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "700"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "900",
          "lineHeight": "1.1",
          "letterSpacing": "-0.03em"
        }
      },
      "core/quote": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontStyle": "italic",
          "fontWeight": "400",
          "lineHeight": "1.6"
        }
      },
      "core/pullquote": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontStyle": "italic",
          "fontWeight": "400",
          "lineHeight": "1.4"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "var:preset|font-size|sm",
          "lineHeight": "1.8"
        }
      }
    }
  }
}
