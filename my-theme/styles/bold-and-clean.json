{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Bold & Clean",
  "settings": {
    "typography": {
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Syne, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Syne",
              "fontWeight": "400 800",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/syne/Syne-VariableFont.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Lora, serif",
          "fontFace": [
            {
              "fontFamily": "Lora",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/lora/Lora-VariableFont.woff2"]
            },
            {
              "fontFamily": "Lora",
              "fontWeight": "400 700",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/lora/Lora-Italic-VariableFont.woff2"]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "lineHeight": "1.75"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "800",
          "lineHeight": "1.0",
          "letterSpacing": "-0.04em",
          "textTransform": "uppercase"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|3xl",
          "fontWeight": "700",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|md",
          "fontWeight": "700",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "700",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "button": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "700",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|sm",
          "fontWeight": "600",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "800",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|4xl",
          "fontWeight": "800",
          "lineHeight": "1.0",
          "letterSpacing": "-0.04em",
          "textTransform": "uppercase"
        }
      },
      "core/quote": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|xl",
          "fontStyle": "italic",
          "fontWeight": "400",
          "lineHeight": "1.6"
        }
      },
      "core/pullquote": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|2xl",
          "fontWeight": "700",
          "letterSpacing": "-0.01em",
          "lineHeight": "1.3"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "var:preset|font-size|sm",
          "lineHeight": "1.8"
        }
      }
    }
  }
}
