{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "860px",
            "wideSize": "1280px"
        },
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#2B2B2B",
                    "name": "Base"
                },
                {
                    "slug": "base-alt",
                    "color": "#1E1E1E",
                    "name": "Base Alt"
                },
                {
                    "slug": "contrast",
                    "color": "#E8E0D0",
                    "name": "Contrast"
                },
                {
                    "slug": "accent",
                    "color": "#C8A96E",
                    "name": "Accent"
                },
                {
                    "slug": "contrast-alt",
                    "color": "#F5F0E8",
                    "name": "Contrast Alt"
                },
                {
                    "slug": "muted",
                    "color": "#B0A99A",
                    "name": "Muted"
                },
                {
                    "slug": "surface",
                    "color": "#3A3632",
                    "name": "Surface"
                },
                {
                    "slug": "deep",
                    "color": "#181614",
                    "name": "Deep"
                }
            ],
            "gradients": [
                {
                    "slug": "base-to-deep",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--base) 0%, var(--wp--preset--color--base-alt) 100%)",
                    "name": "Base to Deep"
                },
                {
                    "slug": "surface-fade",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--surface) 0%, var(--wp--preset--color--base) 100%)",
                    "name": "Surface Fade"
                },
                {
                    "slug": "accent-glow",
                    "gradient": "linear-gradient(135deg, rgba(200,169,110,0.15) 0%, transparent 60%)",
                    "name": "Accent Glow"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Playfair Display', Georgia, 'Times New Roman', serif",
                    "slug": "heading",
                    "name": "Playfair Display"
                },
                {
                    "fontFamily": "'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif",
                    "slug": "body",
                    "name": "Jost"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.8125rem",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "1rem",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "1.25rem",
                    "name": "Large"
                },
                {
                    "slug": "x-large",
                    "size": "1.75rem",
                    "name": "X-Large"
                },
                {
                    "slug": "xx-large",
                    "size": "2.25rem",
                    "name": "XX-Large"
                },
                {
                    "slug": "display",
                    "size": "clamp(2.75rem, 6vw, 3.5rem)",
                    "name": "Display"
                }
            ]
        },
        "spacing": {
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "spacingSizes": [
                {
                    "slug": "10",
                    "size": "0.5rem",
                    "name": "Tiny"
                },
                {
                    "slug": "20",
                    "size": "1rem",
                    "name": "Small"
                },
                {
                    "slug": "30",
                    "size": "1.5rem",
                    "name": "Medium"
                },
                {
                    "slug": "40",
                    "size": "2.5rem",
                    "name": "Large"
                },
                {
                    "slug": "50",
                    "size": "4rem",
                    "name": "X-Large"
                },
                {
                    "slug": "60",
                    "size": "6rem",
                    "name": "XX-Large"
                },
                {
                    "slug": "70",
                    "size": "8rem",
                    "name": "Huge"
                }
            ]
        },
        "custom": {
            "lineHeight": {
                "body": 1.6,
                "heading": 1.15
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif",
            "fontSize": "1rem",
            "fontWeight": "300",
            "lineHeight": "1.6",
            "letterSpacing": "0.02em"
        },
        "spacing": {
            "blockGap": "0"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "'Playfair Display', Georgia, 'Times New Roman', serif",
                    "fontWeight": "500",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.01em"
                },
                "color": {
                    "text": "var(--wp--preset--color--contrast-alt)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "clamp(2.75rem, 6vw, 3.5rem)"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "2.25rem"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "1.75rem"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "1.25rem"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--accent)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--contrast-alt)"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--accent)",
                    "text": "var(--wp--preset--color--base)"
                },
                "typography": {
                    "fontFamily": "'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif",
                    "fontWeight": "400",
                    "letterSpacing": "0.12em",
                    "textTransform": "uppercase",
                    "fontSize": "0.8125rem"
                },
                "border": {
                    "radius": "0"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--contrast-alt)",
                        "text": "var(--wp--preset--color--base)"
                    }
                }
            }
        },
        "blocks": {
            "core/separator": {
                "color": {
                    "text": "color-mix(in srgb, var(--wp--preset--color--contrast) 12%, transparent)"
                },
                "border": {
                    "color": "color-mix(in srgb, var(--wp--preset--color--contrast) 12%, transparent)"
                }
            },
            "core/quote": {
                "typography": {
                    "fontFamily": "'Playfair Display', Georgia, 'Times New Roman', serif",
                    "fontStyle": "italic",
                    "fontSize": "1.25rem"
                },
                "color": {
                    "text": "var(--wp--preset--color--contrast-alt)"
                },
                "border": {
                    "left": {
                        "color": "var(--wp--preset--color--accent)",
                        "width": "2px",
                        "style": "solid"
                    }
                }
            }
        }
    },
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}